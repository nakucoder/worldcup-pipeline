{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3WriteWorldcup",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::miami-worldcup-pipeline-juan",
        "arn:aws:s3:::miami-worldcup-pipeline-juan/*"
      ]
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
      "Resource": "arn:aws:logs:us-east-2:*:*"
    }
  ]
}
